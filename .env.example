# ── LLM Provider (choose ONE) ─────────────────────────────────────────────────
#
# OPTION A: Groq cloud (no local install, free tier)
#   1. Get free key at https://console.groq.com → API Keys
#   2. Uncomment and paste your key below
#   3. Restart server — GET /health will show provider: groq
#
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
#
# OPTION B: Ollama local (runs on your machine, fully offline)
#   1. Install Ollama: https://ollama.com/download
#   2. Run: ollama pull llama3
#   3. Run: ollama serve   (keep terminal open)
#   4. Leave OLLAMA_HOST as default below (or change if Ollama is on another machine)
#   5. Restart server — GET /health will show provider: ollama
#
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest

# ── Embeddings (always local, no API key needed) ──────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB (bot memory storage) ────────────────────────────────────────────
CHROMA_PATH=./chroma_db
